"use strict";

const analyzer = require("../services/analyzer");

describe("TicketAnalyzer", () => {
  // ── Category Classification ─────────────────────────────────

  describe("classifyCategory()", () => {
    test("detects Billing category", () => {
      const { category } = analyzer.analyze("I was charged twice on my invoice this month");
      expect(category).toBe("Billing");
    });

    test("detects Technical category", () => {
      const { category } = analyzer.analyze("The app keeps crashing and throwing a 500 error");
      expect(category).toBe("Technical");
    });

    test("detects Account category", () => {
      const { category } = analyzer.analyze("I cannot access my account, it seems locked");
      expect(category).toBe("Account");
    });

    test("detects Feature Request category", () => {
      const { category } = analyzer.analyze("I would love a dark mode feature in the dashboard");
      expect(category).toBe("Feature Request");
    });

    test("falls back to Other when no keywords match", () => {
      const { category } = analyzer.analyze("Hello, I just wanted to say hi to your team");
      expect(category).toBe("Other");
    });
  });

  // ── Priority Computation ────────────────────────────────────

  describe("computePriority()", () => {
    test("P0 for critical urgency + outage with technical signals", () => {
      const { priority } = analyzer.analyze(
        "URGENT: server is down, complete outage, api error 500, all users affected, need fix asap immediately"
      );
      expect(priority).toBe("P0");
    });

    test("P1 for high-signal technical issue", () => {
      const { priority } = analyzer.analyze("The login API keeps failing with a 500 error, blocking all users");
      expect(["P0", "P1"]).toContain(priority);
    });

    test("P3 for low-signal feature request", () => {
      const { priority } = analyzer.analyze("It would be nice to have a dark mode option someday");
      expect(priority).toBe("P3");
    });
  });

  // ── Urgency Detection ───────────────────────────────────────

  describe("detectUrgency()", () => {
    test("detects critical urgency from 'urgent' and 'asap'", () => {
      const { urgencyLevel } = analyzer.analyze("This is urgent, please fix asap the server is down");
      expect(urgencyLevel).toBe("critical");
    });

    test("returns low urgency for benign messages", () => {
      const { urgencyLevel } = analyzer.analyze("I have a question about the billing section of my account");
      expect(urgencyLevel).toBe("low");
    });
  });

  // ── Confidence Score ────────────────────────────────────────

  describe("confidence score", () => {
    test("returns a number between 0 and 1", () => {
      const { confidence } = analyzer.analyze("My payment failed and I cannot login to my account");
      expect(confidence).toBeGreaterThanOrEqual(0);
      expect(confidence).toBeLessThanOrEqual(1);
    });

    test("returns higher confidence for keyword-dense messages", () => {
      const sparse = analyzer.analyze("Something seems off with my account today");
      const dense = analyzer.analyze("My invoice shows a double charge, the payment failed and my subscription expired");
      expect(dense.confidence).toBeGreaterThan(sparse.confidence);
    });
  });

  // ── Custom Rules ────────────────────────────────────────────

  describe("Custom Rule: Security Escalation", () => {
    test("forces P0 priority and SECURITY_ESCALATION tag on security keywords", () => {
      const result = analyzer.analyze("I think my account was hacked and there was unauthorized access");
      expect(result.priority).toBe("P0");
      expect(result.customTags).toContain("SECURITY_ESCALATION");
    });

    test("forces category to Technical on security breach", () => {
      const result = analyzer.analyze("We detected a security breach and data leak in our system");
      expect(result.category).toBe("Technical");
    });
  });

  describe("Custom Rule: Refund Fast-Track", () => {
    test("tags refund requests with REFUND_REQUEST", () => {
      const result = analyzer.analyze("I need a refund, I was charged twice this month");
      expect(result.customTags).toContain("REFUND_REQUEST");
    });

    test("forces category to Billing for refund requests", () => {
      const result = analyzer.analyze("Please process my refund for the last payment");
      expect(result.category).toBe("Billing");
    });
  });

  // ── Keyword Extraction ──────────────────────────────────────

  describe("extractTopKeywords()", () => {
    test("extracts relevant keywords", () => {
      const { keywords } = analyzer.analyze("My account is locked and I cannot reset my password");
      expect(keywords.length).toBeGreaterThan(0);
    });

    test("returns at most 8 keywords", () => {
      const { keywords } = analyzer.analyze(
        "Invoice payment charge billing subscription refund credit transaction fee overcharged discount coupon plan upgrade"
      );
      expect(keywords.length).toBeLessThanOrEqual(8);
    });
  });

  // ── Input Validation ────────────────────────────────────────

  describe("input validation", () => {
    test("throws on empty input", () => {
      expect(() => analyzer.analyze("")).toThrow();
    });

    test("throws on non-string input", () => {
      expect(() => analyzer.analyze(null)).toThrow();
    });
  });
});